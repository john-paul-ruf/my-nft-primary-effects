{
  "name": "my-nft-primary-effects-plugin-pack",
  "version": "1.0.0",
  "description": "A plugin pack for creating custom visual effects for NFT generation with my-nft-gen and nft-studio",
  "type": "module",
  "main": "my-nft-primary-effects-plugins.js",
  "exports": {
    ".": "./plugin.js"
  },
  "scripts": {
    "render": "node scripts/testRender.js --help",
    "test-all-random-preset": "node scripts/testRender.js --all --preset random --frames 225 --width 1920 --height 1080 --save-frames --validate-loop"
  },
  "dependencies": {
    "my-nft-gen": "1.6.9"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.23.0",
    "babel-jest": "^29.0.0",
    "jest": "^29.0.0"
  },
  "jest": {
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "collectCoverage": true
  },
  "babel": {
    "presets": [
      [
        "@babel/preset-env",
        {
          "targets": {
            "node": "18"
          }
        }
      ]
    ]
  },
  "author": "John Ruf",
  "license": "MIT",
  "keywords": [
    "nft-generation",
    "visual-effects",
    "plugin-pack",
    "generative-art",
    "graphics-processing"
  ]
}
